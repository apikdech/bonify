# Receipt Manager - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Backend Configuration
# =============================================================================

# Server Configuration
SERVER_PORT=8080
SERVER_ENV=development

# Database (PostgreSQL) - REQUIRED
DATABASE_URL=postgres://postgres:postgres@localhost:5432/receipt_manager?sslmode=disable

# Redis - REQUIRED for sessions and caching
REDIS_URL=redis://localhost:6379

# JWT Authentication - REQUIRED
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Object Storage (MinIO/S3) - REQUIRED for receipt images
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=receipts
MINIO_USE_SSL=false

# LLM Provider Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=your-llm-api-key-here

# Temporal Workflow Engine (optional)
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=receipt-tasks

# FX Rates
FX_PROVIDER=exchangerate-api
FX_BASE_CURRENCY=USD
FX_REFRESH_CRON=0 0 * * *

# Bot Integrations (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_PUBLIC_KEY=your-discord-public-key

# Application
APP_URL=http://localhost:8080
OCR_CONFIDENCE_THRESHOLD=0.85

# =============================================================================
# Frontend Configuration
# =============================================================================

# The frontend is primarily configured at build time via Vite.
# For API configuration, the frontend uses relative URLs (/api/v1) by default,
# which works when the backend and frontend are served from the same origin.

# If running frontend separately in development, you can configure the API proxy:
# VITE_API_URL=http://localhost:8080

# For production deployment with separate domains:
# PUBLIC_API_URL=https://api.yourdomain.com
