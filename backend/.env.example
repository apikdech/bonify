# Receipt Manager Backend - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Server Configuration
# =============================================================================

# HTTP server port (default: 8080)
SERVER_PORT=8080

# Application environment: development, staging, production (default: development)
SERVER_ENV=development

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection URL (required)
# Format: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/receipt_manager?sslmode=disable

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis connection URL (default: redis://localhost:6379)
# Format: redis://user:password@host:port/db
REDIS_URL=redis://localhost:6379

# =============================================================================
# JWT Authentication Configuration
# =============================================================================

# JWT signing secret - MUST be set and kept secure (required)
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Access token TTL - duration string like "15m", "1h", "24h" (default: 15m)
JWT_ACCESS_TTL=15m

# Refresh token TTL - duration string like "168h" (7 days), "720h" (30 days) (default: 168h)
JWT_REFRESH_TTL=168h

# =============================================================================
# MinIO / S3 Object Storage Configuration
# =============================================================================

# MinIO/S3 endpoint (default: localhost:9000)
MINIO_ENDPOINT=localhost:9000

# MinIO/S3 access key (required for production)
MINIO_ACCESS_KEY=minioadmin

# MinIO/S3 secret key (required for production)
MINIO_SECRET_KEY=minioadmin

# Bucket name for storing receipt images (default: receipts)
MINIO_BUCKET=receipts

# Use SSL/TLS for MinIO/S3 connections (default: false)
MINIO_USE_SSL=false

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# LLM provider: openai, anthropic, google, ollama (default: openai)
LLM_PROVIDER=openai

# Model name to use (default: gpt-4)
# Examples: gpt-4, gpt-4-turbo, gpt-3.5-turbo, claude-3-opus, gemini-pro
LLM_MODEL=gpt-4

# API key for the LLM provider (required for cloud providers)
LLM_API_KEY=your-llm-api-key-here

# =============================================================================
# Temporal Workflow Configuration
# =============================================================================

# Temporal server host (default: localhost:7233)
TEMPORAL_HOST=localhost:7233

# Temporal namespace (default: default)
TEMPORAL_NAMESPACE=default

# Task queue name for receipt processing workflows (default: receipt-tasks)
TEMPORAL_TASK_QUEUE=receipt-tasks

# =============================================================================
# Foreign Exchange Rate Configuration
# =============================================================================

# FX rate provider: exchangerate-api, openexchangerates (default: exchangerate-api)
FX_PROVIDER=exchangerate-api

# Base currency for conversions (default: USD)
FX_BASE_CURRENCY=USD

# Cron expression for FX rate refresh schedule (default: 0 0 * * * = daily at midnight)
FX_REFRESH_CRON=0 0 * * *

# =============================================================================
# Bot Integration Configuration
# =============================================================================

# Telegram Bot Token from BotFather (required for Telegram bot)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Secret for validating Telegram webhook requests (recommended)
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# Discord Bot Token from Discord Developer Portal (required for Discord bot)
DISCORD_BOT_TOKEN=your-discord-bot-token

# Discord Application Public Key for interaction validation (required for Discord bot)
DISCORD_PUBLIC_KEY=your-discord-public-key

# =============================================================================
# Application Configuration
# =============================================================================

# Public URL of the application (default: http://localhost:8080)
APP_URL=http://localhost:8080

# Minimum OCR confidence threshold for accepting receipt data (default: 0.85)
# Range: 0.0 to 1.0, higher = more strict
OCR_CONFIDENCE_THRESHOLD=0.85
