# Used by docker-compose.yml for api and worker (Docker network hostnames).
# Do not put secrets here — use the project .env or shell for JWT_SECRET, LLM_API_KEY, bot tokens, etc.

SERVER_ENV=production
DATABASE_URL=postgres://postgres:postgres@postgres:5432/receipt_manager?sslmode=disable
REDIS_URL=redis://redis:6379

RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=receipts
RUSTFS_USE_SSL=false
RUSTFS_REGION=us-east-1

TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=receipt-tasks

FX_PROVIDER=exchangerate-api
FX_BASE_CURRENCY=USD
FX_REFRESH_CRON="0 0 * * *"

OCR_CONFIDENCE_THRESHOLD=0.85
